{
  "version": 2,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/online-classes",
      "dest": "/frontend/online-classes.html"
    },
    {
      "src": "/online-classes/",
      "dest": "/frontend/online-classes.html"
    },
    {
      "src": "/online-classes.html",
      "dest": "/frontend/online-classes.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|webp|svg|ico))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
